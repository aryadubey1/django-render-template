# Copy this to .env for local development
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

# Superuser — used by build.sh on Render
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme123

# Database — leave blank for local SQLite, Render sets this automatically
DATABASE_URL=

# Telegram notifications for Contact form
# Get your bot token from @BotFather on Telegram
# Get chat_id by messaging @userinfobot
# These can also be overridden per-project in Admin → Site Settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
